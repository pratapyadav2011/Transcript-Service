GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Transcription: gemini | whisper | whisper_gemini_fallback
TRANSCRIPTION_ENGINE=whisper
WHISPER_MODEL=small.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=8
WHISPER_BATCH_SIZE=8
WHISPER_BEAM_SIZE=1
WHISPER_LANGUAGE=en
WHISPER_MODEL_DIR=/models/whisper
# Optional vocabulary hint, e.g. Pensacola, CivicClerk, council member names
WHISPER_INITIAL_PROMPT=

REDIS_URL=redis://localhost:6379/0
MONGODB_URI=mongodb+srv://user:pass@host/dbname?retryWrites=true&w=majority

UPLOAD_DIR=uploads
LOG_DIR=logs

# Optional: explicit binary paths (auto-detected if not set)
YTDLP_PATH=
FFMPEG_PATH=

# Optional: HTTP/SOCKS proxy for yt-dlp subtitle fetches. Leave empty to fetch
# directly; set only when a media CDN blocks the server's IP.
MEDIA_PROXY_URL=

# ── Auth (no login) ───────────────────────────────────────────────────────────
# Shared secret that locks down the whole service. Used two ways:
#   • server-to-server: send it in the  X-API-Key  header
#   • browser UI: your website mints a short-lived signed token from it
#     (see README → "Securing the service") and links users in with ?token=...
# Generate a strong one with:  openssl rand -hex 32
# If left BLANK, auth is disabled (open) — fine for local dev, never in prod.
API_SECRET_KEY=change_me_to_a_random_secret
